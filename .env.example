# ── bittensor identity ──
GREENFERENCE_MINER_HOTKEY=5F...your_hotkey
GREENFERENCE_MINER_PAYOUT_ADDRESS=5F...your_payout
GREENFERENCE_MINER_AUTH_SECRET=your-shared-secret
GREENFERENCE_MINER_API_BASE_URL=http://127.0.0.1:8006
GREENFERENCE_MINER_VALIDATOR_URL=http://127.0.0.1:8002
GREENFERENCE_MINER_NODE_ID=compute-node-1

# ── hardware ──
GREENFERENCE_GPU_MODEL=a100
GREENFERENCE_GPU_COUNT=1
GREENFERENCE_VRAM_GB_PER_GPU=80
GREENFERENCE_CPU_CORES=32
GREENFERENCE_MEMORY_GB=128
GREENFERENCE_PERFORMANCE_SCORE=1.0
GREENFERENCE_GPU_SPLIT_UNITS=100

# ── security tier ──
# standard | cpu_tee | cpu_gpu_attested
GREENFERENCE_SECURITY_TIER=standard
GREENFERENCE_ATTESTATION_ENABLED=false

# ── backends ──
# pod: process (docker) | stub | k8s
GREENFERENCE_POD_BACKEND=stub
# vm: stub | firecracker | kubevirt
GREENFERENCE_VM_BACKEND=stub

# ── ssh (pod access) ──
GREENFERENCE_SSH_HOST=127.0.0.1
GREENFERENCE_SSH_PORT_RANGE_START=30000
GREENFERENCE_SSH_PORT_RANGE_END=31000

# ── volumes ──
GREENFERENCE_VOLUME_BASE_DIR=/tmp/greenference-compute-volumes

# ── agent loop ──
GREENFERENCE_BOOTSTRAP_MINER=false
GREENFERENCE_ENABLE_BACKGROUND_WORKERS=false
GREENFERENCE_WORKER_POLL_INTERVAL_SECONDS=1.0

# ── workload kinds ──
GREENFERENCE_SUPPORTED_WORKLOAD_KINDS=pod,vm

# ── auth secrets (optional, for route protection) ──
# GREENFERENCE_AGENT_AUTH_SECRET=
# GREENFERENCE_COMPUTE_AUTH_SECRET=
